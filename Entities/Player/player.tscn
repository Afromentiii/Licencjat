[sub_resource type="GDScript" id="GDScript_5cbp6"]
script/source = "extends CharacterBody2D

const SPEED = 300.0
const JUMP_VELOCITY = -400.0

@onready var healthBar = $healthBar

var gravity = ProjectSettings.get_setting(\"physics/2d/default_gravity\")
var reward: int = 0
var previous_pos_x: float = 0.0
var move_end_pos_x: float = 0.0
var iter_stacked_counter: int = 0
var moves: Array = []
var playerID: int = -1
var pos_x: float = 0.0

var is_dead: bool = false
var is_moving_right: bool = false
var is_jumping: bool = false
var respawnPosition: Vector2 = Vector2(10, 10)
var distance_after_death: int = 0

enum AgentMode { DEAD, REPLAYING_LOADED, LIVING }

var mode: AgentMode = AgentMode.DEAD
var current_move_index: int = 0
var next_cycle_time: int = 0
var stop_move_time: int = 0
var active_move_type: int = -1
var original_moves_size: int = 0

func start_replaying_loaded(current_time: int) -> void:
	self.position = respawnPosition
	is_dead = false
	mode = AgentMode.REPLAYING_LOADED
	current_move_index = 0
	next_cycle_time = current_time
	stop_move_time = 0

func start_living(current_time: int) -> void:
	self.reward = 0
	self.position = respawnPosition
	self.is_dead = false
	self.mode = AgentMode.LIVING
	self.current_move_index = 0
	self.iter_stacked_counter = 0
	self.distance_after_death = 0
	self.next_cycle_time = current_time
	self.stop_move_time = 0
	self.original_moves_size = moves.size()

func process_logic(current_time: int) -> void:
	if is_dead or mode == AgentMode.DEAD:
		return
		
	if is_moving_right and current_time >= stop_move_time:
		is_moving_right = false
		
	if current_time >= next_cycle_time:
		if current_move_index > 0:
			move_end_pos_x = pos_x
			var is_randomizing = mode == AgentMode.LIVING and current_move_index > original_moves_size
			
			if move_end_pos_x > previous_pos_x:
				if is_randomizing:
					distance_after_death += abs(respawnPosition.distance_to(Vector2(move_end_pos_x, 0)))
				move_reward(active_move_type)
				
				if is_randomizing:
					iter_stacked_counter = 0
			else:
				if is_randomizing:
					iter_stacked_counter += 1
					reward -= 5
					if iter_stacked_counter == 2:
						for i in range(2):
							if moves.size() > 0:
								moves.pop_back()
						reward -= 375
						respawn()
						return
						
		if is_dead:
			return

		previous_pos_x = pos_x
		
		if mode == AgentMode.REPLAYING_LOADED:
			if current_move_index < moves.size():
				active_move_type = moves[current_move_index]
				execute_move(active_move_type, current_time)
				current_move_index += 1
				next_cycle_time = current_time + 2250
			else:
				moves.clear()
				is_dead = true
				self.position = respawnPosition
				mode = AgentMode.DEAD
				return
				
		elif mode == AgentMode.LIVING:
			if current_move_index < moves.size():
				active_move_type = moves[current_move_index]
			else:
				active_move_type = randi_range(1, 6)
				moves.append(active_move_type)
				
			execute_move(active_move_type, current_time)
			current_move_index += 1
			next_cycle_time = current_time + 2250

func execute_move(move_type: int, current_time: int) -> void:
	var move_duration_ms: int = 0
	is_moving_right = true
	is_jumping = false
	
	match move_type:
		0: move_duration_ms = 100
		1: move_duration_ms = 250
		2: move_duration_ms = 500
		3:
			is_jumping = true
			move_duration_ms = 100
		4:
			is_jumping = true
			move_duration_ms = 250
		5:
			is_jumping = true
			move_duration_ms = 500
		6:
			is_jumping = true
			move_duration_ms = 750
			
	if move_duration_ms == 0:
		is_moving_right = false
	else:
		stop_move_time = current_time + move_duration_ms

func move_reward(move_type: int) -> void:
	match move_type:
		0, 3: reward += 5
		1, 4: reward += 25
		2, 5: reward += 50
		6: reward += 65 

			
func _ready():
	self.position = get_parent().spawnPos

func endGame() -> void:
	reward = 999999
	await get_tree().create_timer(0.75).timeout
	self.is_dead = true
	healthBar.value = 100
	self.position = respawnPosition
	self.is_jumping = false
	self.move_end_pos_x = 0
	self.previous_pos_x = 0
	self.distance_after_death = 0
	self.mode = AgentMode.DEAD

func respawn() -> void:
	self.is_dead = true
	healthBar.value = 100
	self.position = respawnPosition
	self.is_jumping = false
	self.is_moving_right = false
	
	self.move_end_pos_x = 0
	self.previous_pos_x = 0
	self.distance_after_death = 0
	self.mode = AgentMode.DEAD

	
func enemyDMG():
	$healthBar.value -= 100
	reward -= 300
	
func lavaColumn_dmg() -> void:
	reward -= 300
	$healthBar.value -= 100

func blackMatter_dmg() -> void:
	$healthBar.value -= 100
	reward -= 300

func cave_spike_dmg() -> void:
	reward -= 200
	$healthBar.value  -= 100

func hugeJump() -> void:
	velocity.y = -700

func spike_dmg() -> void:
	$healthBar.value -= 10
	velocity.y = JUMP_VELOCITY
	reward -= 5
	
func lava_dmg() -> void:
	$healthBar.value -= 25
	velocity.y = JUMP_VELOCITY
	
func _physics_process(delta):
	
	if healthBar.value <= 0:
		respawn()
	
	pos_x = position.x
	
	if not is_on_floor():
		velocity.y += gravity * delta

	if is_jumping and is_on_floor() and is_dead == false:
		velocity.y = JUMP_VELOCITY
		is_jumping = false

	if is_moving_right and not is_dead:
		velocity.x = SPEED
		$AnimatedSprite2D.play(\"runR\")
	else:
		velocity.x = move_toward(velocity.x, 0, SPEED)
	

	move_and_slide()
"

